                                else if (type === 'Z2') p1.y = 8; // Top sideline
                              }
                            }
                            
                            // Destination follows prolonged direction mapping
                            if (dir && sz && !String(stat.endZone).match(/[A-D]/i)) {
                              const type = [4, 5, 7].includes(sz) ? 'Z4' : ([2, 1, 9].includes(sz) ? 'Z2' : 'Z3');
                              let attackDest = null;
                              
                              if (endHalfLeft) { // Dest is Left court (0-50).
                                if (type === 'Z4') { // Origin Y=83
                                  switch(dir) {
                                    case 1: attackDest = {x: 5, y: 90}; break;
                                    case 2: attackDest = {x: 5, y: 70}; break;
                                    case 3: attackDest = {x: 5, y: 50}; break;
                                    case 4: attackDest = {x: 5, y: 20}; break;
                                    case 5: attackDest = {x: 20, y: 10}; break;
                                    case 6: attackDest = {x: 35, y: 10}; break;
                                    case 7: attackDest = {x: 45, y: 30}; break;
                                  }
                                } else if (type === 'Z2') { // Origin Y=17
                                  switch(dir) {
                                    case 1: attackDest = {x: 5, y: 10}; break;
                                    case 2: attackDest = {x: 5, y: 30}; break;
                                    case 3: attackDest = {x: 5, y: 50}; break;
                                    case 4: attackDest = {x: 5, y: 80}; break;
                                    case 5: attackDest = {x: 20, y: 90}; break;
                                    case 6: attackDest = {x: 35, y: 90}; break;
                                    case 7: attackDest = {x: 45, y: 70}; break;
                                  }
                                } else { // Z3
                                  switch(dir) {
                                    case 1: attackDest = {x: 35, y: 90}; break;
                                    case 2: attackDest = {x: 5, y: 90}; break;
                                    case 3: attackDest = {x: 5, y: 70}; break;
                                    case 4: attackDest = {x: 5, y: 50}; break;
                                    case 5: attackDest = {x: 5, y: 30}; break;
                                    case 6: attackDest = {x: 5, y: 10}; break;
                                    case 7: attackDest = {x: 35, y: 10}; break;
                                    case 8: attackDest = {x: 30, y: 50}; break;
                                  }
                                }
                              } else { // Dest is Right court (50-100).
                                if (type === 'Z4') { // Origin Y=17
                                  switch(dir) {
                                    case 1: attackDest = {x: 95, y: 10}; break;
                                    case 2: attackDest = {x: 95, y: 30}; break;
                                    case 3: attackDest = {x: 95, y: 50}; break;
                                    case 4: attackDest = {x: 95, y: 80}; break;
                                    case 5: attackDest = {x: 80, y: 90}; break;
                                    case 6: attackDest = {x: 65, y: 90}; break;
                                    case 7: attackDest = {x: 55, y: 70}; break;
                                  }
                                } else if (type === 'Z2') { // Origin Y=83
                                  switch(dir) {
                                    case 1: attackDest = {x: 95, y: 90}; break;
                                    case 2: attackDest = {x: 95, y: 70}; break;
                                    case 3: attackDest = {x: 95, y: 50}; break;
                                    case 4: attackDest = {x: 95, y: 20}; break;
                                    case 5: attackDest = {x: 80, y: 10}; break;
                                    case 6: attackDest = {x: 65, y: 10}; break;
                                    case 7: attackDest = {x: 55, y: 30}; break;
                                  }
                                } else { // Z3
                                  switch(dir) {
                                    case 1: attackDest = {x: 65, y: 10}; break;
                                    case 2: attackDest = {x: 95, y: 10}; break;
                                    case 3: attackDest = {x: 95, y: 30}; break;
                                    case 4: attackDest = {x: 95, y: 50}; break;
                                    case 5: attackDest = {x: 95, y: 70}; break;
                                    case 6: attackDest = {x: 95, y: 90}; break;
                                    case 7: attackDest = {x: 65, y: 90}; break;
                                    case 8: attackDest = {x: 70, y: 50}; break;
                                  }
                                }
                              }
                              
                              if (attackDest) {
                                p2 = attackDest;
                              }
                            }
                          }
                          const color = isHomeAction ? homeColor : rivalColor;
                          return (
                            <g>
                              <circle cx={`${p1.x}%`} cy={`${p1.y}%`} r="4" fill={color} />
                              <line 
