                        <defs>
                          <marker id="arrowhead" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
                            <polygon points="0 0, 6 3, 0 6" fill={stat.player?.teamId !== 'rival' ? homeColor : rivalColor} />
                          </marker>
                        </defs>
                        {(() => {
                          const isHomeAction = stat.player?.teamId !== 'rival';
