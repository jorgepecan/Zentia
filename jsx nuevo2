                                else if (subzone === 'B') { coords.x += dx; coords.y += dy; }
                                else if (subzone === 'D') { coords.x -= dx; coords.y -= dy; }
                                else if (subzone === 'A') { coords.x -= dx; coords.y += dy; }
                              } else {
                                // Net at left (-x). Left is bottom (+y), Right is top (-y).
                                if (subzone === 'C') { coords.x -= dx; coords.y += dy; }
                                else if (subzone === 'B') { coords.x -= dx; coords.y -= dy; }
                                else if (subzone === 'D') { coords.x += dx; coords.y += dy; }
