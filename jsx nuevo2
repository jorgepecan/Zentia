                        ],
                        'rece_minus': [{ dStart: 33.33, dEnd: 100, cStart: 0, cEnd: 100, color: 'rgba(244, 162, 97, 0.9)', label: '-' }],
                        'rece_neutral': [{ dStart: 55, dEnd: 100, cStart: 0, cEnd: 100, color: 'rgba(148, 163, 184, 0.85)', label: '/' }],
                        'rece_excl': [
                          { dStart: 0, dEnd: 33.33, cStart: 0, cEnd: 25, color: 'rgba(253, 224, 71, 0.9)', label: '!' },
                          { dStart: 0, dEnd: 33.33, cStart: 75, cEnd: 100, color: 'rgba(253, 224, 71, 0.9)', label: '!' },
                          { dStart: 33.33, dEnd: 45, cStart: 0, cEnd: 50, color: 'rgba(253, 224, 71, 0.9)', label: '!' },
                          { dStart: 33.33, dEnd: 45, cStart: 50, cEnd: 100, color: 'rgba(253, 224, 71, 0.9)', label: '!' }
                        ],
                        'rece_plus': [{ dStart: 0, dEnd: 15, cStart: 45, cEnd: 85, color: 'rgba(74, 222, 128, 0.9)', label: '+' }],
                        'rece_pos': [{ dStart: 0, dEnd: 14, cStart: 53, cEnd: 90, color: 'rgba(22, 163, 74, 0.95)', label: '#' }]
                      }[type] || [];
                      return shapes.map((sh, idx) => (
                        <div key={idx} style={{ ...getStyle(sh.dStart, sh.dEnd, sh.cStart, sh.cEnd), background: sh.color, fontSize: '14px', fontWeight: 'bold', color: '#000' }}>
                          {sh.label && sh.color !== 'transparent' ? sh.label : ''}
                          {sh.color === 'transparent' && sh.label === '!' && <div style={{position:'absolute', bottom:'2px', right:'4px', color:'#000'}}>{sh.label}</div>}
                          {sh.color === 'transparent' && sh.label === '+' && <div style={{position:'absolute', top:'2px', left:'4px', color:'#000'}}>{sh.label}</div>}
