                          const isAttackOrServe = isServe || actionType.includes('attack') || actionType === 'kill' || actionType.includes('atq');
                          const mapZoneToPercent = (zone, isLeftHalf, isServeOrigin = false) => {
                            const zStr = String(zone).toUpperCase();
                            const z = parseInt(zStr);
                            const subzoneMatch = zStr.match(/[A-D]/);
                            const subzone = subzoneMatch ? subzoneMatch[0] : null;
                            const mapLeft = { 1: {x:17, y:83}, 2: {x:42, y:83}, 3: {x:42, y:50}, 4: {x:42, y:17}, 5: {x:17, y:17}, 6: {x:17, y:50}, 7: {x:30, y:17}, 8: {x:30, y:50}, 9: {x:30, y:83} };
                            const mapRight = { 1: {x:83, y:17}, 2: {x:58, y:17}, 3: {x:58, y:50}, 4: {x:58, y:83}, 5: {x:83, y:83}, 6: {x:83, y:50}, 7: {x:70, y:83}, 8: {x:70, y:50}, 9: {x:70, y:17} };
                            
                            let coords = isLeftHalf ? (mapLeft[z] || {x:25, y:50}) : (mapRight[z] || {x:75, y:50});
                            coords = { ...coords }; // clone
                            if (isServeOrigin) {
                              coords.x = isLeftHalf ? 0 : 100;
                            } else if (subzone) {
                              const dx = 4;
                              const dy = 8;
                              if (isLeftHalf) {
                                // Net at right (+x). Left is top (-y), Right is bottom (+y).
