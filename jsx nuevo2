              if (e.key === 'Enter') {
                processDvCommand(dvInputText);
                setSelectedLogIndex(-1);
              } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                setSelectedLogIndex(prev => {
                  if (prev === -1) {
                    return liveStats.length > 0 ? liveStats.length - 1 : -1;
                  }
                  return prev > 0 ? prev - 1 : 0;
                });
              } else if (e.key === 'ArrowDown') {
                e.preventDefault();
                setSelectedLogIndex(prev => {
                  if (prev === -1) {
                    return liveStats.length > 0 ? 0 : -1;
