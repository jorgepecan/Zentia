const MiniCourt = ({ stat, homeColor, rivalColor }) => {
  if (!stat) return <div style={{ width: '100%', aspectRatio: '2 / 1', background: '#d4d4d8', borderRadius: '4px', border: '2px solid #fff' }}></div>;
